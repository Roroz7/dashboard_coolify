{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Monitoring complet VPS OVH — CPU, RAM, Disque, Réseau, Docker",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🖥️ Vue Générale",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU"
      }],
      "title": "CPU Usage",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "RAM"
      }],
      "title": "RAM Usage",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})) * 100",
        "legendFormat": "Disque /"
      }],
      "title": "Disque Usage (/)",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "s",
          "mappings": []
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "node_time_seconds - node_boot_time_seconds",
        "legendFormat": "Uptime"
      }],
      "title": "⏱️ Uptime",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "count(count by (cpu) (node_cpu_seconds_total{mode=\"idle\"}))",
        "legendFormat": "Cores"
      }],
      "title": "🔲 CPU Cores",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "node_memory_MemTotal_bytes",
        "legendFormat": "RAM Total"
      }],
      "title": "💾 RAM Total",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 4 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "node_load1",
        "legendFormat": "Load 1m"
      }],
      "title": "📈 Load Average (1m)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 200 }]
          }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 4 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "node_procs_running",
        "legendFormat": "Processus"
      }],
      "title": "⚙️ Processus actifs",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 4 },
      "id": 9,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "node_filefd_allocated",
        "legendFormat": "FDs"
      }],
      "title": "📂 File Descriptors",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "🔲 CPU",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "Total CPU"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{mode=\"user\"}[5m])) * 100",
          "legendFormat": "User"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{mode=\"system\"}[5m])) * 100",
          "legendFormat": "System"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{mode=\"iowait\"}[5m])) * 100",
          "legendFormat": "IO Wait"
        }
      ],
      "title": "CPU Usage détaillé",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 11,
      "targets": [
        { "expr": "node_load1", "legendFormat": "Load 1m" },
        { "expr": "node_load5", "legendFormat": "Load 5m" },
        { "expr": "node_load15", "legendFormat": "Load 15m" },
        {
          "expr": "count(count by (cpu) (node_cpu_seconds_total{mode=\"idle\"}))",
          "legendFormat": "Nb Cores"
        }
      ],
      "title": "Load Average",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "💾 Mémoire",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 12,
      "targets": [
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Disponible" },
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Utilisée" },
        { "expr": "node_memory_Cached_bytes", "legendFormat": "Cache" },
        { "expr": "node_memory_Buffers_bytes", "legendFormat": "Buffers" }
      ],
      "title": "RAM Usage",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 13,
      "targets": [
        { "expr": "node_memory_SwapTotal_bytes", "legendFormat": "Swap Total" },
        { "expr": "node_memory_SwapFree_bytes", "legendFormat": "Swap Libre" },
        { "expr": "node_memory_SwapTotal_bytes - node_memory_SwapFree_bytes", "legendFormat": "Swap Utilisé" }
      ],
      "title": "Swap",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "💿 Disque",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 14,
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[5m])", "legendFormat": "Lecture — {{ device }}" },
        { "expr": "rate(node_disk_written_bytes_total[5m])", "legendFormat": "Écriture — {{ device }}" }
      ],
      "title": "I/O Disque (bytes/s)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 15,
      "targets": [
        {
          "expr": "rate(node_disk_io_time_seconds_total[5m]) * 1000",
          "legendFormat": "IO Time — {{ device }}"
        }
      ],
      "title": "Latence I/O Disque",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 0, "fillOpacity": 60 }
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 34 },
      "id": 16,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "node_filesystem_size_bytes{fstype!~\"tmpfs|fuse.lxcfs\"}",
          "legendFormat": "Total — {{ mountpoint }}"
        },
        {
          "expr": "node_filesystem_size_bytes{fstype!~\"tmpfs|fuse.lxcfs\"} - node_filesystem_avail_bytes{fstype!~\"tmpfs|fuse.lxcfs\"}",
          "legendFormat": "Utilisé — {{ mountpoint }}"
        }
      ],
      "title": "Espace disque par partition",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "🌐 Réseau",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 17,
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "RX — {{ device }}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "TX — {{ device }}"
        }
      ],
      "title": "Débit réseau (bytes/s)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 18,
      "targets": [
        {
          "expr": "rate(node_network_receive_packets_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "RX pkts — {{ device }}"
        },
        {
          "expr": "rate(node_network_transmit_packets_total{device!~\"lo|docker.*|veth.*\"}[5m])",
          "legendFormat": "TX pkts — {{ device }}"
        }
      ],
      "title": "Paquets réseau (pkts/s)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 49 },
      "id": 19,
      "targets": [
        {
          "expr": "rate(node_network_receive_errs_total{device!~\"lo\"}[5m])",
          "legendFormat": "Erreurs RX — {{ device }}"
        },
        {
          "expr": "rate(node_network_transmit_errs_total{device!~\"lo\"}[5m])",
          "legendFormat": "Erreurs TX — {{ device }}"
        }
      ],
      "title": "Erreurs réseau",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 1000 }]
          }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 49 },
      "id": 20,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "node_netstat_Tcp_CurrEstab", "legendFormat": "TCP Établies" }
      ],
      "title": "Connexions TCP actives",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 },
      "id": 105,
      "title": "🐳 Docker / Conteneurs",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 56 },
      "id": 21,
      "targets": [{
        "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]) * 100",
        "legendFormat": "{{ name }}"
      }],
      "title": "CPU par conteneur (%)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 56 },
      "id": 22,
      "targets": [{
        "expr": "container_memory_usage_bytes{name!=\"\"}",
        "legendFormat": "{{ name }}"
      }],
      "title": "RAM par conteneur",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 64 },
      "id": 23,
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name!=\"\"}[5m])",
          "legendFormat": "RX — {{ name }}"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{name!=\"\"}[5m])",
          "legendFormat": "TX — {{ name }}"
        }
      ],
      "title": "Réseau par conteneur",
      "type": "timeseries"
    }

  ],

  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vps", "ovh", "system", "docker"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Paris",
  "title": "VPS OVH — Monitoring Complet",
  "uid": "vps-ovh-monitoring",
  "version": 1
}
